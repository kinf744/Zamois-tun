<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:id="@+id/section_zivpn"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:visibility="gone">

    <!-- Multi-Profil ZIVPN -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="ZIVPN PROFILES" android:textColor="#4FC3F7" android:textSize="12sp" android:textAllCaps="true"/>
        <Button android:id="@+id/btn_add_zivpn_profile" android:layout_width="36dp" android:layout_height="36dp" android:text="+" android:textSize="20sp" android:backgroundTint="#1565C0" android:textColor="#FFFFFF" android:padding="0dp"/>
    </LinearLayout>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Appui long sur un profil pour le modifier, cloner ou supprimer. Cochez plusieurs profils pour activer le multi-tunnel UDP." android:textColor="#666666" android:textSize="11sp" android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_zivpn_profiles" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false" android:layout_marginBottom="8dp"/>

    <!-- Champs legacy conservés invisibles pour compatibilité code -->
    <EditText android:id="@+id/et_zivpn_host" android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone"/>
    <EditText android:id="@+id/et_zivpn_port" android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone"/>
    <EditText android:id="@+id/et_zivpn_password" android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone"/>

</LinearLayout>
